# LLM Provider Selection
# Options: claude, zhipu
LLM_PROVIDER=zhipu

# Claude Configuration (optional, used when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=your_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ZhipuAI Configuration (optional, used when LLM_PROVIDER=zhipu)
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-5
# Note: OpenAI SDK will append /chat/completions to this base URL
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Common LLM Configuration
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# Environment Configuration
CONDA_ENV_NAME=py12pt
OUTPUT_DIR=./output/generated_code

# Execution Configuration
MAX_RETRIES=3
TIMEOUT_SECONDS=300
ENABLE_CACHE=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./output/logs/multi_agent.log

# PDF Parser Configuration
PDF_PARSER_ENGINE=pdfplumber  # Options: pdfplumber, PyPDF2
EXTRACT_FORMULAS=true
EXTRACT_FIGURES=true
